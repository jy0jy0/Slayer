# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Google (Gemini + OAuth)
GOOGLE_API_KEY=your-google-api-key

# Google OAuth (Supabase 대시보드에 설정된 것과 동일한 client여야 함)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Naver News Search API
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# 공공데이터 포털
DATA_GO_KR_API_KEY=your-data-go-kr-api-key

# Supabase PostgreSQL (Transaction Pooler)
DATABASE_URL=postgresql://postgres.{project-ref}:{password}@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# Supabase
SUPABASE_URL=https://{project-ref}.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# SMTP (이메일 발송 — Gmail App Password 사용)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password
