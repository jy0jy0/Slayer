# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Google (Gemini + OAuth)
GOOGLE_API_KEY=your-google-api-key

# 이력서 파서 LLM 선택 (선택사항)
# "gemini" | "openai" | 미설정(자동 감지: GOOGLE_API_KEY 있으면 Gemini, 없으면 OpenAI)
# SLAYER_PARSER_LLM=gemini

# Naver News Search API
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# 공공데이터 포털
DATA_GO_KR_API_KEY=your-data-go-kr-api-key

# Supabase PostgreSQL (Transaction Pooler)
DATABASE_URL=postgresql://postgres.{project-ref}:{password}@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres
